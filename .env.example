FLASK_ENV=production

# Optional local TLS certs (for direct Flask HTTPS runs)
# SSL_CERT=cert.pem
# SSL_KEY=key.pem

SECRET_KEY=change-me
AGENT_TOKEN=change-me

# Keep this format if your operational setup already uses it.
REGISTRY_URL=http://localhost:5001/v2/

# VNC credentials — Cirrus Labs base images default to admin/admin.
# Apple VNC (RFB 003.889) uses ARD authentication which requires both fields.
VNC_DEFAULT_USERNAME=admin
VNC_DEFAULT_PASSWORD=admin

# Production proxy/HTTPS settings (new)
TRUST_PROXY=true
FORCE_HTTPS=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# Optional overrides
# DATABASE_URL=sqlite:///orchard_ui.db
# WEBSOCKIFY_PORT_MIN=6900
# WEBSOCKIFY_PORT_MAX=6999
# VM_POLL_INTERVAL_MS=5000
# TART_IMAGES=ghcr.io/cirruslabs/macos-sonoma-base:latest,ghcr.io/cirruslabs/macos-tahoe-base:latest
