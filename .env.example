FLASK_ENV=production

# Optional local TLS certs (for direct Flask HTTPS runs)
# SSL_CERT=cert.pem
# SSL_KEY=key.pem

SECRET_KEY=change-me
AGENT_TOKEN=change-me

# Keep this format if your operational setup already uses it.
# In multi-node setups, prefer manager host/IP (not localhost), e.g.:
# REGISTRY_URL=http://192.168.1.195:5001/v2/
REGISTRY_URL=http://localhost:5001/v2/

# VNC credentials — Cirrus Labs base images default to admin/admin.
# Apple VNC (RFB 003.889) uses ARD authentication which requires both fields.
VNC_DEFAULT_USERNAME=admin
VNC_DEFAULT_PASSWORD=admin

# Production proxy/HTTPS settings (new)
TRUST_PROXY=true
FORCE_HTTPS=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# VNC transport — set true to route VNC through SSH tunnel (needed for
# data center / WAN deployments). On LAN, leave false for lower latency.
# VNC_USE_SSH_TUNNEL=false
# Optional browser-direct mode (bypasses Flask WS relay entirely).
# Requires direct browser reachability to node websockify endpoint.
# VNC_BROWSER_DIRECT_NODE_WS=false
# Optional scheme override for direct mode: ws or wss.
# Leave unset for auto (wss on https pages, ws on http pages).
# VNC_BROWSER_DIRECT_NODE_WS_SCHEME=wss

# Optional overrides
# DATABASE_URL=sqlite:///orchard_ui.db
# WEBSOCKIFY_PORT_MIN=6900
# WEBSOCKIFY_PORT_MAX=6999
# VM_POLL_INTERVAL_MS=5000
# TART_IMAGES=ghcr.io/cirruslabs/macos-sonoma-base:latest,ghcr.io/cirruslabs/macos-tahoe-base:latest

# ---- Related manager-node tart_agent env (set in tart_agent .env, not here) ----
# REGISTRY_INSECURE=true
# REGISTRY_DATA_DIR=/Users/Shared/tart-registry
# REGISTRY_CONTAINER_NAME=tart-registry
