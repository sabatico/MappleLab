# Flask
SECRET_KEY=generate-a-random-string-here

# Database (default: SQLite in instance/ folder)
DATABASE_URL=sqlite:///orchard_ui.db

# Local OCI registry (run scripts/setup_registry.sh first)
REGISTRY_URL=192.168.1.100:5001

# Shared secret between Flask server and all TART agents
AGENT_TOKEN=change-me-to-a-strong-random-value

# SSH tunnel port range for VNC console forwarding
WEBSOCKIFY_PORT_MIN=6900
WEBSOCKIFY_PORT_MAX=6999

# VNC default password (TART VMs default to 'admin')
VNC_DEFAULT_PASSWORD=admin

# TLS — leave blank to use plain HTTP
SSL_CERT=
SSL_KEY=

# UI polling interval (ms)
VM_POLL_INTERVAL_MS=5000

# TART images shown in "Create VM" dropdown (comma-separated)
# TART_IMAGES=ghcr.io/cirruslabs/macos-sequoia-vanilla:latest,...
